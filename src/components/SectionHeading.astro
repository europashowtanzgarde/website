---
interface Props {
  number?: string;
  eyebrow?: string;
  title: string;
  intro?: string;
  align?: 'left' | 'center';
}

const { number, eyebrow, title, intro } = Astro.props;
---

<header class="section-heading">
  <div class="section-heading__title">
    {number && <span class="section-heading__number" aria-hidden="true">{number}</span>}
    {eyebrow && <p class="section-heading__context">{eyebrow}</p>}
    <h2>{title}</h2>
  </div>
  {intro && <p class="section-heading__intro">{intro}</p>}
</header>

<style>
  .section-heading {
    display: grid;
    gap: var(--space-4) clamp(2rem, 6vw, 6rem);
    align-items: end;
    margin-bottom: clamp(2rem, 4vw, 3.5rem);
  }

  @media (min-width: 760px) {
    .section-heading:has(.section-heading__intro) {
      grid-template-columns: minmax(0, 1fr) minmax(17rem, 0.65fr);
    }
  }

  .section-heading__title {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2) var(--space-4);
  }

  .section-heading__number {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 750;
    color: var(--red-600);
  }

  .section-heading__context {
    width: 100%;
    font-weight: 700;
    color: var(--red-600);
  }

  .section-heading h2 {
    font-size: var(--step-3);
  }

  .section-heading__intro {
    max-width: 40rem;
    color: var(--text-muted);
    font-size: var(--step-1);
  }
</style>
