---
import type { CollectionEntry } from 'astro:content';
import CmsImage from './CmsImage.astro';
import { formatMonthYear } from '../lib/date';

interface Props {
  album: CollectionEntry<'gallery'>;
}

const { album } = Astro.props;
const { title, date, description, credit, images } = album.data;
---

<section class="album">
  <header class="album__head">
    <div>
      <span class="label">{formatMonthYear(date)}</span>
      <h2 class="album__title">{title}</h2>
      {description && <p class="album__desc">{description}</p>}
    </div>
  </header>

  <div class="album__grid">
    {
      images.map((img, i) => (
        <figure class="album__item" style={`--reveal-index:${i % 6}`}>
          <CmsImage src={img.image} alt={img.alt} seed={`${album.id}-${i}`} ratio="1 / 1" />
          {img.caption && <figcaption>{img.caption}</figcaption>}
        </figure>
      ))
    }
  </div>

  {credit && <p class="album__credit">Fotos: {credit}</p>}
</section>

<style>
  .album + .album {
    margin-top: var(--space-8);
  }

  .album__head {
    margin-bottom: var(--space-5);
  }

  .album__title {
    font-size: var(--step-3);
    margin-top: 0.2rem;
  }

  .album__desc {
    margin-top: 0.5rem;
    max-width: 44rem;
    color: var(--text-muted);
  }

  .album__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: var(--space-3);
  }

  .album__item {
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius-m);
  }

  .album__item :global(img) {
    transition: transform 0.4s var(--ease-out);
  }

  .album__item:hover :global(img) {
    transform: scale(1.05);
  }

  .album__item figcaption {
    margin-top: 0.4rem;
    font-size: var(--step--1);
    color: var(--text-dim);
  }

  .album__credit {
    margin-top: var(--space-4);
    font-size: var(--step--1);
    color: var(--text-dim);
    font-style: italic;
  }
</style>
