---
import type { CollectionEntry } from 'astro:content';
import CmsImage from './CmsImage.astro';
import { formatDate, isoDate } from '../lib/date';

interface Props {
  post: CollectionEntry<'posts'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { title, date, description, cover } = post.data;
const href = `/aktuelles/${post.id}`;
---

<article class:list={['post-teaser', { 'is-featured': featured }]}>
  <a class="post-teaser__media" href={href} tabindex="-1" aria-hidden="true">
    <CmsImage src={cover} alt="" seed={post.id} ratio={featured ? '16 / 10' : '3 / 2'} loading={featured ? 'eager' : 'lazy'} />
  </a>
  <div class="post-teaser__body">
    <time datetime={isoDate(date)}>{formatDate(date)}</time>
    <h3><a href={href}>{title}</a></h3>
    <p>{description}</p>
    <span class="post-teaser__more" aria-hidden="true">Weiterlesen <span>→</span></span>
  </div>
</article>

<style>
  .post-teaser {
    position: relative;
    display: grid;
    gap: var(--space-5);
    padding-block: var(--space-6);
    border-top: 1px solid var(--hairline-strong);
  }

  .post-teaser:last-child {
    border-bottom: 1px solid var(--hairline-strong);
  }

  .post-teaser__media {
    min-width: 0;
    width: 100%;
    max-width: 20rem;
  }

  .post-teaser__body {
    min-width: 0;
    align-self: center;
  }

  .post-teaser time {
    font-size: var(--step--1);
    font-weight: 750;
    color: var(--text-muted);
  }

  .post-teaser h3 {
    margin-top: var(--space-2);
    font-size: var(--step-2);
    color: var(--text);
  }

  .post-teaser h3 a {
    color: inherit;
    text-decoration: none;
  }

  .post-teaser h3 a::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .post-teaser p {
    max-width: 48rem;
    margin-top: var(--space-3);
    color: var(--text-muted);
  }

  .post-teaser__more {
    display: inline-flex;
    gap: 0.45ch;
    margin-top: var(--space-4);
    font-family: var(--font-display);
    font-weight: 750;
    text-transform: uppercase;
    color: var(--accent);
  }

  .post-teaser__more span {
    transition: transform var(--transition-fast);
  }

  .post-teaser:hover h3,
  .post-teaser:focus-within h3 {
    color: var(--accent);
  }

  .post-teaser:hover .post-teaser__more span,
  .post-teaser:focus-within .post-teaser__more span {
    transform: translateX(3px);
  }

  @media (min-width: 680px) {
    .post-teaser {
      grid-template-columns: minmax(13rem, 0.65fr) minmax(0, 1.35fr);
      gap: clamp(2rem, 5vw, 5rem);
    }

    .post-teaser.is-featured {
      grid-template-columns: minmax(16rem, 0.85fr) minmax(18rem, 1.15fr);
      padding-block: 0 var(--space-7);
      border-top: 0;
    }

    .post-teaser.is-featured h3 {
      font-size: var(--step-3);
    }

    .post-teaser.is-featured .post-teaser__media {
      max-width: 28rem;
    }
  }
</style>
