---
import type { CollectionEntry } from 'astro:content';
import CmsImage from './CmsImage.astro';
import { formatDate, isoDate } from '../lib/date';

interface Props {
  post: CollectionEntry<'posts'>;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { title, date, description, cover, coverAlt } = post.data;
const href = `/aktuelles/${post.id}`;
---

<article class:list={['post-card', { 'is-featured': featured }]}>
  <a class="post-card__media" href={href} tabindex="-1" aria-hidden="true">
    <CmsImage
      src={cover}
      alt={coverAlt}
      seed={post.id}
      ratio={featured ? '16 / 10' : '3 / 2'}
      loading={featured ? 'eager' : 'lazy'}
    />
  </a>
  <div class="post-card__body">
    <time class="label" datetime={isoDate(date)}>{formatDate(date)}</time>
    <h3 class="post-card__title">
      <a href={href}>{title}</a>
    </h3>
    <p class="post-card__desc">{description}</p>
    <span class="arrow-link" aria-hidden="true">
      Weiterlesen
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2">
        <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </span>
  </div>
</article>

<style>
  .post-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-l);
    overflow: hidden;
    transition: transform 0.28s var(--ease-out), border-color 0.28s var(--ease-out),
      box-shadow 0.3s var(--ease-out);
  }

  .post-card:hover {
    transform: translateY(-5px);
    border-color: var(--hairline-strong);
    box-shadow: var(--shadow-lift);
  }

  .post-card__media :global(img),
  .post-card__media :global(.ph) {
    border-radius: 0;
  }

  .post-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: var(--space-5);
  }

  .post-card__title {
    font-size: var(--step-2);
    line-height: var(--leading-snug);
  }

  .post-card__title a {
    color: var(--text);
  }

  .post-card__title a::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .post-card:hover .post-card__title a {
    color: var(--accent-bright);
  }

  .post-card__desc {
    color: var(--text-muted);
    font-size: var(--step-0);
  }

  .post-card__body {
    position: relative;
  }

  .arrow-link {
    margin-top: 0.3rem;
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.95rem;
  }

  @media (min-width: 720px) {
    .post-card.is-featured {
      flex-direction: row;
      align-items: stretch;
    }

    .post-card.is-featured .post-card__media {
      flex: 1 1 55%;
      display: block;
    }

    .post-card.is-featured .post-card__media :global(img),
    .post-card.is-featured .post-card__media :global(.ph) {
      height: 100%;
    }

    .post-card.is-featured .post-card__body {
      flex: 1 1 45%;
      justify-content: center;
      padding: var(--space-7);
    }

    .post-card.is-featured .post-card__title {
      font-size: var(--step-3);
    }
  }
</style>
