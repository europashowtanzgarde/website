---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';
import { site } from '../lib/settings';

const nav = [
  { href: '/aktuelles', label: 'Aktuelles' },
  { href: '/termine', label: 'Termine' },
  { href: '/sparten', label: 'Sparten' },
  { href: '/verein', label: 'Verein' },
  { href: '/galerie', label: 'Galerie' },
  { href: '/kontakt', label: 'Kontakt' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---

<header class="site-header">
  <div class="wrap header-inner">
    <a class="brand" href="/" aria-label={`${site.name} – Startseite`}>
      <Image src={logo} alt={site.name} width={240} class="brand__logo" loading="eager" />
    </a>

    <input type="checkbox" id="nav-toggle" class="nav-toggle visually-hidden" />
    <label for="nav-toggle" class="nav-burger" aria-label="Menü ein- und ausblenden">
      <span></span><span></span><span></span>
    </label>

    <nav class="site-nav" aria-label="Hauptnavigation">
      <ul>
        {
          nav.map((item) => (
            <li>
              <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, #ffffff 82%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--hairline);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    min-height: 4.4rem;
    padding-block: 0.6rem;
  }

  /* --- Wortmarke (echtes Vereinslogo) --- */
  .brand {
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }

  .brand__logo {
    height: clamp(34px, 4.5vw, 46px);
    width: auto;
    transition: transform 0.3s var(--ease-out);
  }

  .brand:hover .brand__logo {
    transform: scale(1.03);
  }

  /* --- Navigation (Desktop) --- */
  .site-nav ul {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2.5vw, 2rem);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .site-nav a {
    position: relative;
    display: inline-block;
    padding: 0.4em 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--text);
  }

  /* Diagonale „Wisch"-Unterstreichung (Signatur). */
  .site-nav a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -1px;
    width: 100%;
    height: 3px;
    background: var(--hot);
    transform: scaleX(0) skewX(-20deg);
    transform-origin: left;
    transition: transform 0.28s var(--ease-out);
  }

  .site-nav a:hover,
  .site-nav a[aria-current='page'] {
    color: var(--accent);
  }

  .site-nav a:hover::after,
  .site-nav a[aria-current='page']::after {
    transform: scaleX(1) skewX(-20deg);
  }

  /* --- Burger (nur mobil sichtbar) --- */
  .nav-toggle {
    position: absolute;
  }

  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 10px;
    cursor: pointer;
    border-radius: var(--radius-s);
  }

  .nav-burger span {
    display: block;
    height: 2.5px;
    width: 100%;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.25s var(--ease-out), opacity 0.2s var(--ease-out);
  }

  .nav-toggle:focus-visible + .nav-burger {
    outline: 3px solid var(--hot-bright);
    outline-offset: 2px;
  }

  @media (max-width: 899px) {
    .nav-burger {
      display: flex;
    }

    .site-nav {
      position: absolute;
      left: 0;
      right: 0;
      top: 100%;
      background: #ffffff;
      border-bottom: 1px solid var(--hairline-strong);
      box-shadow: var(--shadow-card);
      overflow: hidden;
      max-height: 0;
      transition: max-height 0.32s var(--ease-out);
    }

    .site-nav ul {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .site-nav li {
      border-top: 1px solid var(--hairline);
    }

    .site-nav a {
      display: block;
      padding: 1rem clamp(1.1rem, 4vw, 2.5rem);
      font-size: 1.3rem;
    }

    .site-nav a::after {
      display: none;
    }

    .site-nav a[aria-current='page'] {
      color: var(--accent-bright);
      box-shadow: inset 4px 0 0 var(--hot);
    }

    /* Aufklappen via max-height (animierbar, kein JS). */
    .nav-toggle:checked ~ .site-nav {
      max-height: 80vh;
      overflow-y: auto;
    }

    .nav-toggle:checked + .nav-burger span:nth-child(1) {
      transform: translateY(7.5px) rotate(45deg);
    }

    .nav-toggle:checked + .nav-burger span:nth-child(2) {
      opacity: 0;
    }

    .nav-toggle:checked + .nav-burger span:nth-child(3) {
      transform: translateY(-7.5px) rotate(-45deg);
    }
  }
</style>
