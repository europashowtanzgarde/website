---
import { site } from '../lib/settings';
import SocialIcon from './SocialIcon.astro';

const year = new Date().getFullYear();
const navigation = [
  { href: '/aktuelles', label: 'Aktuelles' },
  { href: '/termine', label: 'Termine' },
  { href: '/sparten', label: 'Sparten' },
  { href: '/verein', label: 'Verein' },
  { href: '/galerie', label: 'Galerie' },
  { href: '/kontakt', label: 'Kontakt' },
];

const social = [
  { href: site.social.facebook, label: 'Facebook', platform: 'facebook' as const },
  { href: site.social.instagram, label: 'Instagram', platform: 'instagram' as const },
  { href: site.social.tiktok, label: 'TikTok', platform: 'tiktok' as const },
].filter((item) => Boolean(item.href));
---

<footer class="site-footer">
  <div class="wrap footer-main">
    <div class="footer-brand">
      <p class="footer-wordmark">Europa Show <span>Tanzgarde</span></p>
      <p>{site.claim}</p>
      {
        social.length > 0 && (
          <ul class="footer-social" aria-label="Social Media">
            {social.map((item) => (
              <li>
                <a
                  class="footer-social__link"
                  href={item.href}
                  target="_blank"
                  rel="noopener"
                  aria-label={`${item.label} (öffnet in einem neuen Tab)`}
                  title={item.label}
                >
                  <SocialIcon platform={item.platform} />
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>

    <nav class="footer-nav" aria-label="Seitennavigation">
      <ul>
        {navigation.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>

    <div class="footer-contact">
      <p class="footer-title">Kontakt</p>
      <a href={`mailto:${site.email}`}>{site.email}</a>
      <p>{site.location}</p>
    </div>
  </div>

  <div class="wrap footer-bottom">
    <p>© {year} {site.name}. {site.footerText}</p>
    <p class="footer-legal"><a href="/impressum">Impressum</a><a href="/datenschutz">Datenschutz</a></p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: clamp(2rem, 5vw, 4rem);
    color: var(--text-on-color);
    background: var(--night-900);
  }

  .footer-main {
    display: grid;
    gap: var(--space-7);
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  @media (min-width: 760px) {
    .footer-main {
      grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
      align-items: start;
    }

    .footer-contact {
      grid-column: 1 / -1;
    }
  }

  @media (min-width: 900px) {
    .footer-main {
      grid-template-columns: minmax(18rem, 1.5fr) minmax(0, 1fr) minmax(0, 1fr);
    }

    .footer-contact {
      grid-column: auto;
    }
  }

  .footer-wordmark {
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: 800;
    line-height: 1;
    text-transform: uppercase;
  }

  .footer-wordmark span {
    color: var(--red-400);
  }

  .footer-brand > p:nth-child(2) {
    max-width: 28rem;
    margin-top: var(--space-3);
    color: var(--text-on-color-muted);
  }

  .footer-social,
  .footer-nav ul {
    list-style: none;
    padding: 0;
  }

  .footer-social {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-5);
  }

  .footer-social .footer-social__link {
    justify-content: center;
    width: 44px;
    height: 44px;
    min-height: 44px;
    color: var(--text-on-color);
    background: rgb(255 255 255 / 0.06);
    border: 1px solid rgb(255 255 255 / 0.24);
    border-radius: var(--radius-s);
    text-decoration: none;
    transition: color var(--transition-fast), background-color var(--transition-fast), border-color var(--transition-fast), transform var(--transition-fast);
  }

  .footer-social .footer-social__link:hover {
    color: #ffffff;
    background: var(--red-600);
    border-color: var(--red-600);
    transform: translateY(-2px);
  }

  .footer-nav ul {
    columns: 2;
    column-gap: var(--space-6);
  }

  .footer-nav li {
    break-inside: avoid;
    margin-bottom: var(--space-2);
  }

  .site-footer a {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    color: var(--text-on-color);
  }

  .site-footer a:hover {
    color: var(--red-300);
  }

  .footer-title {
    margin-bottom: var(--space-2);
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 750;
    text-transform: uppercase;
  }

  .footer-contact > p:last-child {
    color: var(--text-on-color-muted);
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-4) var(--space-6);
    padding-block: var(--space-5);
    border-top: 1px solid rgb(255 255 255 / 0.16);
    font-size: var(--step--1);
    color: var(--text-on-color-muted);
  }

  .footer-legal {
    display: flex;
    gap: var(--space-5);
  }

  .footer-legal a {
    min-height: 28px;
  }
</style>
