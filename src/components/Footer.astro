---
import { site } from '../lib/settings';

const year = new Date().getFullYear();

const columns = [
  {
    title: 'Entdecken',
    links: [
      { href: '/aktuelles', label: 'Aktuelles' },
      { href: '/termine', label: 'Termine' },
      { href: '/sparten', label: 'Sparten' },
      { href: '/galerie', label: 'Galerie' },
    ],
  },
  {
    title: 'Verein',
    links: [
      { href: '/verein', label: 'Über uns' },
      { href: '/kontakt', label: 'Kontakt' },
      { href: '/impressum', label: 'Impressum' },
      { href: '/datenschutz', label: 'Datenschutz' },
    ],
  },
];

const hasFacebook = Boolean(site.social.facebook);
const hasInstagram = Boolean(site.social.instagram);
const hasTiktok = Boolean(site.social.tiktok);
---

<footer class="site-footer">
  <div class="wrap footer-grid">
    <div class="footer-brand">
      <p class="footer-wordmark">
        Europa Show <span>Tanzgarde</span>
      </p>
      <p class="footer-claim">{site.claim}</p>
      {
        (hasFacebook || hasInstagram || hasTiktok) && (
          <div class="socials">
            {hasFacebook && (
              <a href={site.social.facebook} class="social" aria-label="Facebook" rel="noopener" target="_blank">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
                  <path d="M14 8.5h2.5V5.5H14c-2.2 0-3.5 1.5-3.5 3.7V11H8v3h2.5v7h3v-7H16l.5-3h-3V9.4c0-.6.3-.9 1-.9Z" />
                </svg>
              </a>
            )}
            {hasInstagram && (
              <a href={site.social.instagram} class="social" aria-label="Instagram" rel="noopener" target="_blank">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <rect x="3.5" y="3.5" width="17" height="17" rx="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17" cy="7" r="1.1" fill="currentColor" stroke="none" />
                </svg>
              </a>
            )}
            {hasTiktok && (
              <a href={site.social.tiktok} class="social" aria-label="TikTok" rel="noopener" target="_blank">
                <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
                  <path d="M16.5 3c.3 2 1.5 3.6 3.5 4v2.6c-1.3.05-2.6-.35-3.7-1.05v5.7a5.35 5.35 0 1 1-5.35-5.35c.3 0 .6.03.9.08v2.7a2.65 2.65 0 1 0 1.85 2.52V3h2.8Z" />
                </svg>
              </a>
            )}
          </div>
        )
      }
    </div>

    {
      columns.map((col) => (
        <nav class="footer-col" aria-label={col.title}>
          <h2>{col.title}</h2>
          <ul>
            {col.links.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      ))
    }

    <div class="footer-col">
      <h2>Kontakt</h2>
      <ul>
        <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
      </ul>
    </div>
  </div>

  <div class="wrap footer-bottom">
    <p>© {year} {site.name}. {site.footerText}</p>
    <p class="footer-legal">
      <a href="/impressum">Impressum</a>
      <span aria-hidden="true">·</span>
      <a href="/datenschutz">Datenschutz</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    margin-top: var(--space-6);
    padding-top: var(--space-7);
    background: linear-gradient(180deg, transparent, var(--bg-deep) 55%);
    border-top: 1px solid var(--hairline);
    overflow: hidden;
  }

  .footer-grid {
    position: relative;
    display: grid;
    gap: var(--space-6) var(--space-7);
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .footer-grid {
      grid-template-columns: 1.4fr 1fr 1fr;
    }
  }

  @media (min-width: 900px) {
    .footer-grid {
      grid-template-columns: 2fr 1fr 1fr 1.2fr;
    }
  }

  .footer-wordmark {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    line-height: 1;
  }

  .footer-wordmark span {
    color: var(--accent-bright);
  }

  .footer-claim {
    margin-top: 0.6rem;
    max-width: 22rem;
    color: var(--text-muted);
    font-size: var(--step--1);
  }

  .socials {
    display: flex;
    gap: 0.7rem;
    margin-top: 1.2rem;
  }

  .social {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    color: var(--text);
    border: 1px solid var(--hairline-strong);
    transition: transform 0.2s var(--ease-out), color 0.2s var(--ease-out),
      border-color 0.2s var(--ease-out), box-shadow 0.25s var(--ease-out);
  }

  .social:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-3px);
    box-shadow: var(--glow-blue-soft);
  }

  .footer-col h2 {
    font-family: var(--font-display);
    font-size: 0.95rem;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.9rem;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.55rem;
  }

  .footer-col a {
    color: var(--text-muted);
  }

  .footer-col a:hover {
    color: var(--accent);
  }

  .footer-bottom {
    position: relative;
    margin-top: var(--space-7);
    padding-block: var(--space-5);
    border-top: 1px solid var(--hairline);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-5);
    justify-content: space-between;
    align-items: center;
    font-size: var(--step--1);
    color: var(--text-dim);
  }

  .footer-legal {
    display: inline-flex;
    gap: 0.6rem;
    align-items: center;
  }

  .footer-legal a {
    color: var(--text-muted);
  }

  .footer-legal a:hover {
    color: var(--accent);
  }
</style>
