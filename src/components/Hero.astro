---
import { homepage } from '../lib/settings';

const { heroKicker } = homepage;
---

<section class="photo-hero" aria-label="Die Europa-Show-Tanzgarde auf der Bühne">
  <img
    class="photo-hero__img"
    src="/uploads/ensemble-buehne.webp"
    alt="Die gesamte Europa-Show-Tanzgarde auf der Bühne, in blau-roten Kostümen unter farbigem Bühnenlicht."
    fetchpriority="high"
    decoding="async"
  />

  <div class="photo-hero__overlay">
    {heroKicker && <p class="photo-hero__kicker">{heroKicker}</p>}
    <p class="photo-hero__showtime">It&rsquo;s&nbsp;Showtime</p>
  </div>
</section>

<style>
  .photo-hero {
    position: relative;
    width: 100%;
    height: clamp(26rem, 80svh, 50rem);
    isolation: isolate;
    overflow: hidden;
  }

  .photo-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 28%;
  }

  /* Weicher Verlaufs-Scrim: unten + links dunkler, damit die weiße
     Schrift sicher lesbar auf dem Foto sitzt. */
  .photo-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(to top, rgb(9 12 29 / 0.8), rgb(9 12 29 / 0.15) 42%, transparent 68%),
      linear-gradient(to right, rgb(9 12 29 / 0.55), transparent 55%);
  }

  .photo-hero__overlay {
    position: absolute;
    inset: auto auto 0 0;
    z-index: 2;
    padding: clamp(1.4rem, 5vw, 3.5rem);
    max-width: min(94%, 52rem);
    display: grid;
    gap: var(--space-4);
  }

  .photo-hero__kicker {
    font-family: var(--font-script);
    font-size: var(--step-2);
    line-height: 1;
    color: #ffffff;
    text-shadow: 0 2px 14px rgb(0 0 0 / 0.5);
    transform: rotate(var(--skew));
    transform-origin: left center;
    margin: 0;
  }

  .photo-hero__showtime {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    color: #ffffff;
    line-height: 0.9;
    font-size: clamp(2.8rem, 10vw, 6.5rem);
    letter-spacing: 0.01em;
    text-shadow: 0 6px 34px rgb(0 0 0 / 0.55);
    margin: 0;
  }

  @media (max-width: 560px) {
    .photo-hero__img {
      object-position: center 22%;
    }
  }
</style>
