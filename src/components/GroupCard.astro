---
import type { CollectionEntry } from 'astro:content';
import CmsImage from './CmsImage.astro';

interface Props {
  group: CollectionEntry<'groups'>;
  index?: number;
  variant?: 'summary' | 'detail';
}

const { group, variant = 'detail' } = Astro.props;
const { name, description, ageGroup, trainingTime, contact, image, imageAlt } = group.data;
---

<article class:list={['group-profile', `is-${variant}`]}>
  <div class="group-profile__media">
    <CmsImage src={image} alt={imageAlt || name} seed={group.id} ratio={variant === 'summary' ? '16 / 10' : '16 / 9'} />
  </div>
  <div class="group-profile__body">
    {ageGroup && <p class="group-profile__age">{ageGroup}</p>}
    <h3>{name}</h3>
    <p class="group-profile__description">{description}</p>
    {
      (trainingTime || contact) && (
        <dl class="group-profile__facts">
          {trainingTime && <div><dt>Training</dt><dd>{trainingTime}</dd></div>}
          {contact && <div><dt>Ansprechperson</dt><dd>{contact}</dd></div>}
        </dl>
      )
    }
  </div>
</article>

<style>
  .group-profile {
    min-width: 0;
    border-top: 1px solid var(--hairline-strong);
  }

  .group-profile__media {
    min-width: 0;
    width: 100%;
    max-width: 28rem;
  }

  .group-profile__media :global(img),
  .group-profile__media :global(.ph) {
    border-radius: 0;
  }

  .group-profile__body {
    min-width: 0;
    padding-block: var(--space-5) var(--space-6);
  }

  .group-profile__age {
    margin-bottom: var(--space-2);
    font-size: var(--step--1);
    font-weight: 750;
    color: var(--red-700);
  }

  .group-profile h3 {
    max-width: 18ch;
    font-size: var(--step-2);
  }

  .group-profile__description {
    max-width: var(--measure);
    margin-top: var(--space-3);
    color: var(--text-muted);
  }

  .group-profile__facts {
    display: grid;
    gap: var(--space-3);
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    border-top: 1px solid var(--hairline);
  }

  .group-profile__facts div {
    display: grid;
    grid-template-columns: minmax(6rem, 0.45fr) 1fr;
    gap: var(--space-4);
  }

  .group-profile__facts dt {
    font-size: var(--step--1);
    font-weight: 750;
    color: var(--text-muted);
  }

  .group-profile__facts dd {
    margin: 0;
  }

  @media (min-width: 720px) {
    .group-profile.is-detail {
      display: grid;
      grid-template-columns: minmax(14rem, 0.62fr) minmax(0, 1.38fr);
      gap: clamp(2rem, 5vw, 5rem);
      align-items: center;
      padding-block: clamp(2rem, 4vw, 3.5rem);
    }

    .group-profile.is-detail:nth-child(even) {
      grid-template-columns: minmax(0, 1.38fr) minmax(14rem, 0.62fr);
    }

    .group-profile.is-detail:nth-child(even) .group-profile__media {
      grid-column: 2;
    }

    .group-profile.is-detail:nth-child(even) .group-profile__body {
      grid-column: 1;
      grid-row: 1;
    }

    .group-profile.is-detail .group-profile__media :global(img),
    .group-profile.is-detail .group-profile__media :global(.ph) {
      border-radius: var(--radius-m);
    }
  }

  @media (min-width: 860px) {
    .group-profile.is-summary:nth-child(2) {
      margin-top: var(--space-7);
    }

    .group-profile.is-summary:nth-child(3) {
      margin-top: calc(var(--space-7) * 2);
    }
  }
</style>
