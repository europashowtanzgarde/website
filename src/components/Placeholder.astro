---
interface Props {
  seed?: string;
  label?: string;
  ratio?: string;
  class?: string;
}

const { seed = 'bild', label = 'Foto folgt', ratio = '4 / 3', class: klass } = Astro.props;
---

<div
  class:list={['ph', klass]}
  style={`--ph-ratio:${ratio};`}
  data-seed={seed}
  role="img"
  aria-label={label}
>
  <span>{label}</span>
</div>

<style>
  .ph {
    display: grid;
    width: 100%;
    aspect-ratio: var(--ph-ratio);
    place-items: end start;
    overflow: hidden;
    padding: var(--space-4);
    border: 1px dashed var(--border-strong);
    border-radius: var(--radius-m);
    background: var(--surface-soft-blue);
  }

  .ph span {
    font-size: var(--step--1);
    font-weight: 750;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
</style>
