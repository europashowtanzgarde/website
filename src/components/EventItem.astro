---
import type { CollectionEntry } from 'astro:content';
import { formatDay, formatMonthShort, formatWeekday, formatTime, isoDate } from '../lib/date';

interface Props {
  event: CollectionEntry<'events'>;
  showDescription?: boolean;
  past?: boolean;
}

const CATEGORY_LABELS: Record<string, string> = {
  auftritt: 'Auftritt',
  training: 'Training',
  veranstaltung: 'Veranstaltung',
  vereinsintern: 'Vereinsintern',
  sonstiges: 'Sonstiges',
};

const { event, showDescription = false, past = false } = Astro.props;
const { title, date, time, location, description, category } = event.data;
const timeLabel = formatTime(time);
---

<article class:list={['event', { 'is-past': past }]}>
  <time class="event__date" datetime={isoDate(date)}>
    <span>{formatDay(date)}</span>
    <abbr title={formatMonthShort(date)}>{formatMonthShort(date)}</abbr>
  </time>
  <div class="event__body">
    <div class="event__meta">
      <span class="badge" data-cat={category}>{CATEGORY_LABELS[category]}</span>
      <span>{formatWeekday(date)}{timeLabel && ` · ${timeLabel}`}</span>
    </div>
    <h3>{title}</h3>
    <p class="event__location">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M12 21s7-5.5 7-11a7 7 0 1 0-14 0c0 5.5 7 11 7 11Z" stroke-linejoin="round" />
        <circle cx="12" cy="10" r="2.5" />
      </svg>
      {location}
    </p>
    {showDescription && description && <p class="event__description">{description}</p>}
  </div>
</article>

<style>
  .event {
    display: grid;
    grid-template-columns: 3.6rem minmax(0, 1fr);
    gap: var(--space-4);
    padding-block: clamp(1.5rem, 3vw, 2.25rem);
    border-top: 1px solid var(--hairline-strong);
  }

  .event:last-child {
    border-bottom: 1px solid var(--hairline-strong);
  }

  .event.is-past {
    color: var(--text-muted);
  }

  .event__date {
    display: flex;
    flex-direction: column;
    align-items: center;
    align-self: start;
    padding-block: 0.35rem;
    border-top: 3px solid var(--red-600);
    font-variant-numeric: tabular-nums;
    text-decoration: none;
    color: var(--blue-700);
  }

  .event__date span {
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: 800;
    line-height: 1;
  }

  .event__date abbr {
    font-size: var(--step--1);
    font-weight: 750;
    letter-spacing: 0.06em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .event__body {
    min-width: 0;
  }

  .event__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2) var(--space-3);
    font-size: var(--step--1);
    color: var(--text-muted);
  }

  .event h3 {
    margin-top: var(--space-3);
    font-size: var(--step-2);
    color: var(--text);
  }

  .event__location {
    display: flex;
    align-items: flex-start;
    gap: 0.4rem;
    margin-top: var(--space-2);
    color: var(--text-muted);
  }

  .event__location svg {
    flex: none;
    margin-top: 0.3em;
    color: var(--red-600);
  }

  .event__description {
    max-width: var(--measure);
    margin-top: var(--space-4);
    color: var(--text-muted);
  }

  @media (min-width: 680px) {
    .event {
      grid-template-columns: 5rem minmax(0, 1fr);
      gap: var(--space-6);
    }
  }
</style>
