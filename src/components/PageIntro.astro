---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
}

const { eyebrow, title, intro } = Astro.props;
---

<header class="page-intro">
  <div class="wrap page-intro__inner">
    <div class="page-intro__title">
      {eyebrow && <p class="page-intro__context">{eyebrow}</p>}
      <h1>{title}</h1>
    </div>
    {intro && <p class="page-intro__text">{intro}</p>}
  </div>
</header>

<style>
  .page-intro {
    padding-block: clamp(3rem, 8vw, 7rem) clamp(2.25rem, 5vw, 4rem);
    border-bottom: 1px solid var(--hairline);
  }

  .page-intro__inner {
    display: grid;
    gap: var(--space-5) clamp(2rem, 7vw, 7rem);
    align-items: end;
  }

  .page-intro__title,
  .page-intro__text {
    min-width: 0;
  }

  @media (min-width: 780px) {
    .page-intro__inner {
      grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 0.75fr);
    }
  }

  .page-intro__context {
    margin-bottom: var(--space-3);
    font-weight: 700;
    color: var(--red-600);
  }

  .page-intro h1 {
    width: 100%;
    max-width: 15ch;
    font-size: clamp(2.8rem, 2.1rem + 3.1vw, 5.1rem);
    overflow-wrap: normal;
    word-break: normal;
    hyphens: none;
  }

  .page-intro__text {
    max-width: 42rem;
    padding-bottom: 0.3em;
    font-size: var(--step-1);
    color: var(--text-muted);
  }
</style>
