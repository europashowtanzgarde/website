---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
}

const { eyebrow, title, intro } = Astro.props;
---

<section class="page-intro">
  <div class="page-intro__dots formation-dots" aria-hidden="true"></div>
  <div class="wrap page-intro__inner">
    {eyebrow && <p class="eyebrow rise" style="--rise-index:0">{eyebrow}</p>}
    <h1 class="display rise" style="--rise-index:1">{title}</h1>
    {intro && <p class="page-intro__text rise" style="--rise-index:2">{intro}</p>}
  </div>
</section>

<style>
  .page-intro {
    position: relative;
    padding-top: clamp(2.5rem, 6vw, 4.5rem);
    padding-bottom: clamp(1.5rem, 4vw, 2.5rem);
    overflow: hidden;
    isolation: isolate;
  }

  .page-intro__dots {
    position: absolute;
    inset: -30% 0 auto 0;
    height: 140%;
    z-index: -1;
    -webkit-mask-image: radial-gradient(60% 70% at 20% 0%, #000, transparent 70%);
    mask-image: radial-gradient(60% 70% at 20% 0%, #000, transparent 70%);
  }

  .page-intro .eyebrow {
    font-size: var(--step-1);
    transform-origin: left center;
  }

  .page-intro h1 {
    font-size: var(--step-5);
    max-width: 16ch;
  }

  .page-intro__text {
    margin-top: var(--space-4);
    max-width: 48rem;
    font-size: var(--step-1);
    color: var(--text-muted);
  }
</style>
