---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageIntro from '../components/PageIntro.astro';
import CmsImage from '../components/CmsImage.astro';

const timeline = [
  {
    year: '1971',
    title: 'Die Wurzeln',
    text: 'Zwei Tänzerinnen begeistern bei einer Beat-Party in Wassertrüdingen – der Funke für das Tanzen in der Gruppe ist gelegt.',
  },
  {
    year: '1981',
    title: 'Die Gründung',
    text: 'Sechs junge Frauen gründen die „Trüdinger Swinging Girls". Schon wenige Monate später folgt der erste Auftritt beim Altstadtfest.',
  },
  {
    year: '1982',
    title: 'Erstes Programm & Jugendgarde',
    text: 'Mit dem Can-Can steht das erste große Programm auf der Bühne. Aus dem Zulauf jüngerer Tänzerinnen entsteht die Jugend-Tanzgarde.',
  },
  {
    year: '1984',
    title: 'Die Kindergarde',
    text: 'Für die Jüngsten wird die Kindergarde gegründet – seitdem tanzen bei uns drei Generationen unter einem Dach.',
  },
  {
    year: '1987',
    title: 'Der Name „Europa"',
    text: 'Die Europa-Union Deutschland verleiht der Garde den Namen „Europa-Tanzgarde" – im Dienst des europäischen Einigungsgedankens. Daher das „Europa" in unserem Namen.',
  },
  {
    year: '2016',
    title: '35 Jahre',
    text: 'Ein Rückblick auf dreieinhalb Jahrzehnte Showtanz, Auftritte und Vereinsleben.',
  },
  {
    year: '2021',
    title: '„40+1" Jahre',
    text: 'Das um ein Jahr verschobene Jubiläum wird in der Hesselberghalle gefeiert.',
  },
];

const werte = [
  {
    title: 'Showtanz',
    text: 'Aufwendige Choreografien mit Ausdruck, Requisiten und wechselnden Themen – die große Bühne für kreative Auftritte.',
  },
  {
    title: 'Gardetanz',
    text: 'Präzision, Disziplin und Synchronität. Der Gardetanz lebt vom perfekten Zusammenspiel der ganzen Formation.',
  },
  {
    title: 'Zusammenhalt',
    text: 'Hinter jedem Auftritt steckt ehrenamtliches Engagement: Training, Kostüme, Organisation. Bei uns zählt das Miteinander.',
  },
];
---

<BaseLayout
  title="Der Verein"
  description="Seit 1981 steht die Europa-Show-Tanzgarde für Showtanz, Gardetanz und Vereinsleben in Wassertrüdingen. Unsere Geschichte und was uns ausmacht."
>
  <PageIntro
    eyebrow="unsere Geschichte"
    title="Ein Verein aus Wassertrüdingen"
    intro="Was 1981 als kleine Tanzgruppe begann, ist heute ein fester Teil des örtlichen Vereinslebens."
  />

  <section class="section--tight">
    <div class="wrap">
      <figure class="ensemble">
        <CmsImage
          src="/uploads/ensemble-buehne.webp"
          alt="Die gesamte Europa-Show-Tanzgarde auf der Bühne, in blau-roten Kostümen unter farbigem Bühnenlicht."
          ratio="2000 / 940"
          loading="eager"
        />
        <figcaption>Alle drei Garden gemeinsam auf der Bühne. <span>Foto: HahGold Fotografie</span></figcaption>
      </figure>
    </div>
  </section>

  <section class="section section--tight">
    <div class="wrap">
      <ol class="timeline reveal-group">
        {
          timeline.map((item, i) => (
            <li class="timeline__item" style={`--reveal-index:${i}`}>
              <span class="timeline__year">{item.year}</span>
              <div class="timeline__content">
                <h2>{item.title}</h2>
                <p>{item.text}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section section--tight">
    <div class="wrap namensgeschichte">
      <figure class="urkunde">
        <CmsImage
          src="/uploads/urkunde-1987.webp"
          alt="Urkunde der Europa-Union Deutschland von 1987 mit den Flaggen europäischer Länder und der Verleihung des Namens Europa-Tanzgarde Wassertrüdingen."
          ratio="1500 / 1049"
        />
      </figure>
      <div class="namensgeschichte__text">
        <span class="eyebrow">woher der Name kommt</span>
        <h2 class="display">„Europa" im Namen</h2>
        <p>
          Am 11. Juli 1987 verlieh die Europa-Union Deutschland der Garde den Namen
          <strong>Europa-Tanzgarde Wassertrüdingen</strong> – verbunden mit dem Auftrag,
          sich für den europäischen Einigungsgedanken einzusetzen. Dieses Stück
          Vereinsgeschichte tragen wir bis heute im Namen.
        </p>
      </div>
    </div>
  </section>

  <section class="surface-cream">
    <div class="wrap">
      <span class="eyebrow">was uns ausmacht</span>
      <h2 class="display werte-title">Zwei Tanzstile, ein Team</h2>
      <div class="werte">
        {
          werte.map((w) => (
            <article class="werte__card">
              <h3>{w.title}</h3>
              <p>{w.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap">
      <div class="cta-band">
        <div>
          <span class="eyebrow">mitmachen</span>
          <h2 class="display">Werde Teil der Garde</h2>
          <p>Ob tanzen, helfen oder unterstützen – im Verein ist Platz für alle.</p>
        </div>
        <a class="btn" href="/kontakt">Kontakt aufnehmen</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0;
    max-width: 46rem;
  }

  .timeline__item {
    display: grid;
    grid-template-columns: 5rem 1fr;
    gap: var(--space-4);
    padding-block: var(--space-5);
    position: relative;
  }

  .timeline__item::before {
    content: '';
    position: absolute;
    left: calc(5rem + var(--space-4) / 2);
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--hairline);
  }

  .timeline__item:first-child::before {
    top: 50%;
  }

  .timeline__item:last-child::before {
    bottom: 50%;
  }

  .timeline__year {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--step-2);
    color: var(--accent-bright);
    text-align: right;
  }

  .timeline__content {
    position: relative;
    padding-left: var(--space-5);
  }

  .timeline__content::before {
    content: '';
    position: absolute;
    left: calc(var(--space-4) / -2 - 5px);
    top: 0.55em;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--hot);
    box-shadow: var(--glow-red);
  }

  .timeline__content h2 {
    font-size: var(--step-1);
    line-height: var(--leading-snug);
  }

  .timeline__content p {
    margin-top: 0.4rem;
    color: var(--text-muted);
  }

  .werte-title {
    font-size: var(--step-3);
    margin-block: 0.3rem var(--space-6);
  }

  .werte {
    display: grid;
    gap: var(--space-5);
  }

  @media (min-width: 760px) {
    .werte {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .werte__card {
    padding: var(--space-5);
    background: var(--cream-50);
    border: 1px solid var(--cream-hairline);
    border-radius: var(--radius-l);
    border-top: 4px solid var(--red-500);
  }

  .werte__card h3 {
    font-size: var(--step-2);
    color: var(--blue-600);
    margin-bottom: 0.5rem;
  }

  .werte__card p {
    color: var(--cream-ink-muted);
  }

  .cta-band {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-5);
    align-items: center;
    justify-content: space-between;
    padding: var(--space-7);
    border-radius: var(--radius-l);
    border: 1px solid var(--hairline);
    background:
      radial-gradient(90% 140% at 0% 0%, rgb(75 99 230 / 0.16), transparent 55%),
      var(--bg-card);
  }

  .cta-band h2 {
    font-size: var(--step-3);
    margin-block: 0.3rem 0.5rem;
  }

  .cta-band p {
    color: var(--text-muted);
  }

  /* Ensemble-Foto */
  .ensemble {
    margin: 0;
    position: relative;
  }

  .ensemble :global(img) {
    width: 100%;
    border-radius: var(--radius-l);
    box-shadow: var(--shadow-lift);
  }

  .ensemble figcaption {
    margin-top: var(--space-3);
    font-size: var(--step--1);
    color: var(--text-muted);
  }

  .ensemble figcaption span {
    color: var(--text-dim);
  }

  /* Namensgeschichte mit Urkunde */
  .namensgeschichte {
    display: grid;
    gap: var(--space-6);
    align-items: center;
  }

  @media (min-width: 820px) {
    .namensgeschichte {
      grid-template-columns: 0.85fr 1fr;
    }
  }

  .urkunde {
    margin: 0;
  }

  .urkunde :global(img) {
    width: 100%;
    border-radius: var(--radius-m);
    box-shadow: var(--shadow-card);
    border: 1px solid var(--hairline);
  }

  .namensgeschichte__text h2 {
    font-size: var(--step-3);
    margin-block: 0.3rem 0.7rem;
  }

  .namensgeschichte__text p {
    color: var(--text-muted);
    font-size: var(--step-1);
    max-width: 40rem;
  }
</style>
