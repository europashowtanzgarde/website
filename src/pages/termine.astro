---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageIntro from '../components/PageIntro.astro';
import EventItem from '../components/EventItem.astro';
import { getUpcomingEvents, getPastEvents } from '../lib/collections';
import { isoDate } from '../lib/date';
import { site } from '../lib/settings';

const upcoming = await getUpcomingEvents();
const past = await getPastEvents(8);
const eventsLd = upcoming.map((e) => ({
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: e.data.title,
  startDate: e.data.time ? `${isoDate(e.data.date)}T${e.data.time}` : isoDate(e.data.date),
  eventStatus: 'https://schema.org/EventScheduled',
  location: { '@type': 'Place', name: e.data.location },
  organizer: { '@type': 'Organization', name: site.name },
  ...(e.data.description ? { description: e.data.description } : {}),
}));
---

<BaseLayout title="Termine & Auftritte" description="Kommende Auftritte, Feste und Veranstaltungen der Europa-Show-Tanzgarde aus Wassertrüdingen.">
  <Fragment slot="head">
    {eventsLd.map((ld) => <script type="application/ld+json" is:inline set:html={JSON.stringify(ld)} />)}
  </Fragment>

  <PageIntro title="Termine & Auftritte" intro="Wo und wann unsere Garden als Nächstes auf der Bühne stehen." />

  <section class="section section--tight">
    <div class="wrap events-page">
      <h2>Kommende Termine</h2>
      {
        upcoming.length === 0 ? (
          <p class="empty-state">Aktuell sind keine öffentlichen Termine eingetragen. Folgt uns auf Social Media, um nichts zu verpassen.</p>
        ) : (
          <div class="events-page__list">{upcoming.map((event) => <EventItem event={event} showDescription />)}</div>
        )
      }
    </div>
  </section>

  {
    past.length > 0 && (
      <section class="section section--tight events-past">
        <div class="wrap events-page">
          <h2>Rückblick</h2>
          <p class="events-past__intro">Vergangene Auftritte und Veranstaltungen.</p>
          <div class="events-page__list">{past.map((event) => <EventItem event={event} past />)}</div>
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .events-page {
    display: grid;
    gap: var(--space-5) clamp(2rem, 7vw, 7rem);
  }

  @media (min-width: 820px) {
    .events-page {
      grid-template-columns: 13rem minmax(0, 48rem);
      align-items: start;
    }

    .events-page__list,
    .empty-state,
    .events-past__intro {
      grid-column: 2;
    }
  }

  .events-page h2 {
    font-size: var(--step-2);
  }

  .events-past {
    background: var(--surface-soft);
    border-block: 1px solid var(--hairline);
  }

  .events-past__intro {
    color: var(--text-muted);
  }
</style>
