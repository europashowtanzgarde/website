---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageIntro from '../components/PageIntro.astro';
import GalleryAlbum from '../components/GalleryAlbum.astro';
import Placeholder from '../components/Placeholder.astro';
import { getGalleryAlbums } from '../lib/collections';

const albums = await getGalleryAlbums();
---

<BaseLayout
  title="Galerie"
  description="Bilder aus Training, Auftritten und dem Vereinsleben der Europa-Show-Tanzgarde."
>
  <PageIntro
    eyebrow="Einblicke"
    title="Galerie"
    intro="Eindrücke aus Training, Auftritten und dem Vereinsleben – Schritt für Schritt gepflegt."
  />

  <section class="section section--tight">
    <div class="wrap">
      {
        albums.length === 0 ? (
          <div class="gallery-empty">
            <div class="gallery-empty__grid" aria-hidden="true">
              <Placeholder seed="galerie-a" ratio="1 / 1" label="Foto folgt" />
              <Placeholder seed="galerie-b" ratio="1 / 1" label="Foto folgt" />
              <Placeholder seed="galerie-c" ratio="1 / 1" label="Foto folgt" />
              <Placeholder seed="galerie-d" ratio="1 / 1" label="Foto folgt" />
            </div>
            <div class="gallery-empty__text">
              <h2>Die Galerie füllt sich gerade</h2>
              <p>
                Wir sammeln Fotos aus Auftritten und Training. Bald gibt es hier viel
                zu sehen. Bis dahin findet ihr aktuelle Bilder auf unseren
                Social-Media-Kanälen.
              </p>
              <a class="btn btn--ghost" href="/kontakt">Fotos beisteuern?</a>
            </div>
          </div>
        ) : (
          <div class="albums">
            {albums.map((album) => <GalleryAlbum album={album} />)}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .gallery-empty {
    display: grid;
    gap: var(--space-6);
    align-items: center;
  }

  @media (min-width: 800px) {
    .gallery-empty {
      grid-template-columns: 1.1fr 1fr;
    }
  }

  .gallery-empty__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }

  .gallery-empty__text h2 {
    font-size: var(--step-3);
    margin-bottom: 0.7rem;
  }

  .gallery-empty__text p {
    color: var(--text-muted);
    font-size: var(--step-1);
    margin-bottom: var(--space-5);
    max-width: 34rem;
  }
</style>
