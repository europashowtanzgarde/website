---
import { render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CmsImage from '../../components/CmsImage.astro';
import { getPublishedPosts } from '../../lib/collections';
import { formatDate, isoDate } from '../../lib/date';

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const { title, date, description, cover, coverAlt, gallery } = post.data;
const { Content } = await render(post);
---

<BaseLayout title={title} description={description} ogImage={cover ?? '/og-default.png'} article>
  <article class="post">
    <header class="post__head">
      <div class="wrap post__head-inner">
        <a class="post__back" href="/aktuelles">
          <span aria-hidden="true">←</span> Alle Beiträge
        </a>
        <div class="post__title-block">
          <time datetime={isoDate(date)}>{formatDate(date)}</time>
          <h1>{title}</h1>
          <p>{description}</p>
        </div>
      </div>
    </header>

    {cover && <div class="wrap post__cover"><CmsImage src={cover} alt={coverAlt} ratio="16 / 9" loading="eager" /></div>}

    <div class="wrap post__content">
      <div class="prose"><Content /></div>

      {
        gallery.length > 0 && (
          <section class="post__gallery" aria-labelledby="bilder-title">
            <h2 id="bilder-title">Bilder</h2>
            <div class="post__gallery-grid">
              {gallery.map((img, i) => <CmsImage src={img.image} alt={img.alt} seed={`${post.id}-${i}`} ratio="1 / 1" />)}
            </div>
          </section>
        )
      }
    </div>
  </article>
</BaseLayout>

<style>
  .post__head {
    padding-block: clamp(3rem, 8vw, 7rem) clamp(2rem, 5vw, 4rem);
    border-bottom: 1px solid var(--hairline);
  }

  .post__head-inner {
    display: grid;
    gap: var(--space-6) clamp(2rem, 7vw, 7rem);
  }

  @media (min-width: 760px) {
    .post__head-inner {
      grid-template-columns: 10rem minmax(0, 1fr);
    }
  }

  .post__back {
    display: inline-flex;
    min-height: 44px;
    align-items: center;
    align-self: start;
    gap: 0.4ch;
    font-weight: 700;
    color: var(--text-muted);
  }

  .post__title-block time {
    font-size: var(--step--1);
    font-weight: 750;
    color: var(--red-700);
  }

  .post__title-block h1 {
    max-width: 16ch;
    margin-top: var(--space-3);
    font-size: var(--step-4);
    overflow-wrap: anywhere;
  }

  .post__title-block p {
    max-width: 46rem;
    margin-top: var(--space-4);
    font-size: var(--step-1);
    color: var(--text-muted);
  }

  .post__cover {
    max-width: 60rem;
    margin-block: clamp(2rem, 5vw, 4rem);
  }

  .post__cover :global(img) {
    max-height: 42rem;
  }

  .post__content {
    padding-bottom: var(--section-space);
  }

  .post__gallery {
    margin-top: var(--section-space);
    padding-top: var(--space-6);
    border-top: 1px solid var(--hairline-strong);
  }

  .post__gallery h2 {
    font-size: var(--step-2);
  }

  .post__gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 10rem), 1fr));
    gap: var(--space-4);
    margin-top: var(--space-5);
  }
</style>
