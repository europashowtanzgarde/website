---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Seite nicht gefunden" noindex>
  <section class="notfound">
    <div class="wrap notfound__inner">
      <p class="notfound__code" aria-hidden="true">404</p>
      <div>
        <p class="notfound__context">Vorhang zu</p>
        <h1>Diese Seite ist nicht auf der Bühne</h1>
        <p class="notfound__text">Der gesuchte Auftritt wurde verschoben oder gibt es nicht mehr. Von hier kommst du schnell zurück:</p>
        <div class="notfound__actions">
          <a class="btn" href="/">Zur Startseite</a>
          <a class="btn btn--ghost" href="/termine">Zu den Terminen</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .notfound {
    min-height: 68svh;
    display: grid;
    place-items: center;
    padding-block: var(--section-space);
  }

  .notfound__inner {
    display: grid;
    gap: var(--space-6) clamp(2rem, 8vw, 8rem);
    align-items: center;
  }

  @media (min-width: 700px) {
    .notfound__inner {
      grid-template-columns: minmax(10rem, 0.55fr) minmax(0, 1.45fr);
    }
  }

  .notfound__code {
    font-family: var(--font-display);
    font-size: clamp(6rem, 18vw, 12rem);
    font-weight: 800;
    line-height: 0.75;
    color: var(--surface-soft-blue);
    -webkit-text-stroke: 2px var(--blue-700);
  }

  .notfound__context {
    margin-bottom: var(--space-2);
    font-weight: 750;
    color: var(--red-700);
  }

  .notfound h1 {
    font-size: var(--step-4);
  }

  .notfound__text {
    max-width: 38rem;
    margin-top: var(--space-4);
    color: var(--text-muted);
    font-size: var(--step-1);
  }

  .notfound__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }
</style>
