---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PostCard from '../components/PostCard.astro';
import EventItem from '../components/EventItem.astro';
import GroupCard from '../components/GroupCard.astro';
import { getPublishedPosts, getUpcomingEvents, getGroups } from '../lib/collections';
import { homepage, site } from '../lib/settings';

const posts = (await getPublishedPosts()).slice(0, 2);
const events = await getUpcomingEvents(3);
const groups = await getGroups();
const { notice, vereinTeaserTitle, vereinTeaserText } = homepage;
---

<BaseLayout>
  <h1 class="visually-hidden">Europa-Show-Tanzgarde e.V. – Showtanz und Gardetanz aus Wassertrüdingen</h1>
  <Hero />

  {
    notice.enabled && notice.text && (
      <aside class="notice" aria-label="Aktueller Hinweis">
        <div class="wrap notice__inner">
          <p>{notice.text}</p>
          {notice.link && notice.linkLabel && <a class="arrow-link" href={notice.link}>{notice.linkLabel}</a>}
        </div>
      </aside>
    )
  }

  {
    events.length > 0 && (
      <section class="section home-program">
        <div class="wrap">
          <SectionHeading title="Kommende Termine" intro="Wo wir als Nächstes auf der Bühne stehen." />
          <div class="home-program__list">
            {events.map((event) => <EventItem event={event} />)}
          </div>
          <a class="arrow-link home-more" href="/termine">Alle Termine ansehen <span aria-hidden="true">→</span></a>
        </div>
      </section>
    )
  }

  <section class="section rule-section">
    <div class="wrap">
      <SectionHeading title="Für jedes Alter" intro="Drei Garden, ein gemeinsamer Auftritt: von den ersten Schritten bis zu den Aktiven." />
      <div class="groups-index">
        {groups.map((group) => <GroupCard group={group} variant="summary" />)}
      </div>
      <a class="arrow-link home-more" href="/sparten">Alle Garden kennenlernen <span aria-hidden="true">→</span></a>
    </div>
  </section>

  {
    posts.length > 0 && (
      <section class="section rule-section">
        <div class="wrap">
          <SectionHeading title="Aktuelles" intro="Berichte und Neuigkeiten direkt aus dem Vereinsleben." />
          <div class="posts-list">
            {posts.map((post) => <PostCard post={post} />)}
          </div>
          <a class="arrow-link home-more" href="/aktuelles">Alle Beiträge lesen <span aria-hidden="true">→</span></a>
        </div>
      </section>
    )
  }

  <section class="club-story">
    <div class="wrap club-story__inner">
      <div>
        <p class="club-story__since">Seit 1981 in Wassertrüdingen</p>
        <h2>{vereinTeaserTitle}</h2>
      </div>
      <div class="club-story__content">
        <p>{vereinTeaserText}</p>
        <ul class="club-story__facts" aria-label="Vereinsfakten">
          <li><strong>1981</strong> gegründet</li>
          <li><strong>3</strong> Garden</li>
          <li>zuhause in <strong>{site.location}</strong></li>
        </ul>
        <div class="club-story__actions">
          <a class="btn club-story__primary" href="/verein">Mehr über uns</a>
          <a class="btn btn--ghost" href="/kontakt">Mitmachen &amp; Kontakt</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .notice {
    color: var(--text);
    background: #fff0f1;
    border-bottom: 1px solid #e3aeb2;
  }

  .notice__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2) var(--space-5);
    padding-block: var(--space-4);
  }

  .notice__inner::before {
    content: '';
    width: 0.65rem;
    height: 0.65rem;
    border-radius: 50%;
    background: var(--red-600);
  }

  .home-program__list {
    max-width: 58rem;
  }

  .home-more {
    margin-top: var(--space-5);
  }

  .groups-index {
    display: grid;
    gap: var(--space-6);
  }

  @media (min-width: 680px) and (max-width: 859px) {
    .groups-index {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: start;
    }
  }

  @media (min-width: 860px) {
    .groups-index {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      align-items: start;
    }
  }

  .posts-list {
    max-width: 62rem;
  }

  .club-story {
    padding-block: var(--section-space);
    color: var(--text-on-color);
    background: var(--surface-blue);
  }

  .club-story__inner {
    display: grid;
    gap: var(--space-7) clamp(var(--space-8), 9vw, calc(var(--space-8) * 2));
  }

  @media (min-width: 1200px) {
    .club-story__inner {
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    }
  }

  .club-story__since {
    margin-bottom: var(--space-3);
    font-weight: 700;
    color: var(--red-300);
  }

  .club-story h2 {
    max-width: 15ch;
    font-size: var(--step-4);
    color: var(--text-on-color);
    overflow-wrap: normal;
    word-break: normal;
  }

  .club-story__content > p {
    max-width: 42rem;
    font-size: var(--step-1);
    color: var(--text-on-color-muted);
  }

  .club-story__facts {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-6);
    margin-top: var(--space-6);
    padding: var(--space-4) 0;
    border-block: 1px solid rgb(255 255 255 / 0.25);
    list-style: none;
  }

  .club-story__facts li {
    min-width: 0;
    color: var(--text-on-color-muted);
  }

  .club-story__facts strong {
    color: var(--text-on-color);
  }

  .club-story__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  .club-story__primary {
    color: var(--blue-700);
    background: #ffffff;
    border-color: #ffffff;
  }

  .club-story__primary:hover {
    color: var(--blue-700);
    background: var(--surface-soft-blue);
    border-color: var(--surface-soft-blue);
  }

  .club-story .btn--ghost {
    color: #ffffff;
    border-color: rgb(255 255 255 / 0.65);
  }

  .club-story .btn--ghost:hover {
    color: #ffffff;
    background: rgb(255 255 255 / 0.12);
    border-color: #ffffff;
  }
</style>
