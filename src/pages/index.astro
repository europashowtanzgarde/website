---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PostCard from '../components/PostCard.astro';
import EventItem from '../components/EventItem.astro';
import GroupCard from '../components/GroupCard.astro';
import { getPublishedPosts, getUpcomingEvents, getGroups } from '../lib/collections';
import { homepage, site } from '../lib/settings';

const posts = (await getPublishedPosts()).slice(0, 2);
const events = await getUpcomingEvents(3);
const groups = await getGroups();
const { highlights, notice, vereinTeaserTitle, vereinTeaserText } = homepage;
---

<BaseLayout>
  <Hero />

  {
    notice.enabled && notice.text && (
      <div class="notice" role="status">
        <div class="wrap notice__inner">
          <span class="notice__dot" aria-hidden="true"></span>
          <p>{notice.text}</p>
          {notice.link && notice.linkLabel && (
            <a class="arrow-link" href={notice.link}>{notice.linkLabel}</a>
          )}
        </div>
      </div>
    )
  }

  <!-- Schnelle Einstiege -->
  {
    highlights.length > 0 && (
      <section class="section section--tight">
        <div class="wrap">
          <ul class="highlights reveal-group">
            {highlights.map((h, i) => (
              <li class="highlight" style={`--reveal-index:${i}`}>
                <span class="highlight__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
                <h2>{h.title}</h2>
                <p>{h.text}</p>
                <a class="arrow-link" href={h.link}>
                  {h.linkLabel}
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round" /></svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <!-- Kommende Termine -->
  {
    events.length > 0 && (
      <section class="section">
        <div class="wrap">
          <SectionHeading number="01" eyebrow="Bühne frei" title="Kommende Termine" intro="Wo wir als Nächstes auf der Bühne stehen." />
          <div class="events-list">
            {events.map((event) => <EventItem event={event} />)}
          </div>
          <a class="btn btn--ghost more-btn" href="/termine">Alle Termine ansehen</a>
        </div>
      </section>
    )
  }

  <!-- Unsere Garden -->
  <section class="section">
    <div class="wrap">
      <SectionHeading number="02" eyebrow="drei Garden" title="Für jedes Alter" intro="Von den ersten Schritten bis zur großen Bühne." />
      <div class="grid grid--3">
        {groups.map((group, i) => <GroupCard group={group} index={i} />)}
      </div>
    </div>
  </section>

  <!-- Aktuelles -->
  {
    posts.length > 0 && (
      <section class="section">
        <div class="wrap">
          <SectionHeading number="03" eyebrow="frisch aus dem Verein" title="Aktuelles" />
          <div class="grid grid--2">
            {posts.map((post) => <PostCard post={post} />)}
          </div>
          <a class="btn btn--ghost more-btn" href="/aktuelles">Alle Beiträge</a>
        </div>
      </section>
    )
  }

  <!-- Verein-Teaser & Mitmachen -->
  <section class="surface-cream">
    <div class="wrap verein-teaser">
      <div class="verein-teaser__text">
        <span class="eyebrow">seit 1981</span>
        <h2 class="display">{vereinTeaserTitle}</h2>
        <p>{vereinTeaserText}</p>
        <div class="verein-teaser__cta">
          <a class="btn" href="/verein">Mehr über uns</a>
          <a class="btn btn--ghost" href="/kontakt">Mitmachen &amp; Kontakt</a>
        </div>
      </div>
      <div class="verein-teaser__facts" aria-hidden="false">
        <div><strong>1981</strong><span>gegründet</span></div>
        <div><strong>3</strong><span>Garden</span></div>
        <div><strong>{site.location}</strong><span>zuhause</span></div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Aktueller Hinweis */
  .notice {
    background: color-mix(in srgb, var(--hot) 16%, var(--night-850));
    border-block: 1px solid color-mix(in srgb, var(--hot) 40%, transparent);
  }

  .notice__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem 1rem;
    padding-block: 0.9rem;
  }

  .notice__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--hot);
    box-shadow: var(--glow-red);
    flex: none;
  }

  .notice p {
    margin: 0;
    font-weight: 500;
  }

  /* Highlights */
  .highlights {
    display: grid;
    gap: var(--space-5);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (min-width: 720px) {
    .highlights {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .highlight {
    position: relative;
    padding: var(--space-5);
    background: var(--bg-card);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-l);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    overflow: hidden;
    transition: transform 0.25s var(--ease-out), border-color 0.25s var(--ease-out);
  }

  .highlight:hover {
    transform: translateY(-4px);
    border-color: var(--hairline-strong);
  }

  .highlight::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 4px;
    background: linear-gradient(var(--accent), var(--hot));
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.3s var(--ease-out);
  }

  .highlight:hover::before {
    transform: scaleY(1);
  }

  .highlight__num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.1em;
    color: var(--hot-bright);
  }

  .highlight h2 {
    font-size: var(--step-2);
  }

  .highlight p {
    color: var(--text-muted);
    flex: 1;
  }

  .events-list {
    border-bottom: 1px solid var(--hairline);
  }

  .more-btn {
    margin-top: var(--space-6);
  }

  /* Verein-Teaser (helle Sektion) */
  .verein-teaser {
    display: grid;
    gap: var(--space-7);
    align-items: center;
  }

  @media (min-width: 860px) {
    .verein-teaser {
      grid-template-columns: 1.5fr 1fr;
    }
  }

  .verein-teaser__text h2 {
    font-size: var(--step-3);
    margin-block: 0.4rem 0.8rem;
  }

  .verein-teaser__text p {
    max-width: 40rem;
    font-size: var(--step-1);
    color: var(--cream-ink-muted);
  }

  .verein-teaser__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-5);
  }

  .verein-teaser__facts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    text-align: center;
  }

  .verein-teaser__facts div {
    padding: var(--space-4) var(--space-2);
    border: 1px solid var(--cream-hairline);
    border-radius: var(--radius-m);
    background: var(--cream-50);
  }

  .verein-teaser__facts strong {
    display: block;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.3rem, 1rem + 1.5vw, 2rem);
    line-height: 1;
    color: var(--blue-600);
  }

  .verein-teaser__facts span {
    font-size: var(--step--1);
    color: var(--cream-ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
</style>
