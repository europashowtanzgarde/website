---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import PostCard from '../components/PostCard.astro';
import EventItem from '../components/EventItem.astro';
import GroupCard from '../components/GroupCard.astro';
import { getPublishedPosts, getUpcomingEvents, getGroups } from '../lib/collections';
import { homepage, site } from '../lib/settings';

const posts = (await getPublishedPosts()).slice(0, 2);
const events = await getUpcomingEvents(3);
const groups = await getGroups();
const { notice, vereinTeaserTitle, vereinTeaserText } = homepage;
---

<BaseLayout>
  <h1 class="visually-hidden">Europa-Show-Tanzgarde e.V. – Showtanz und Gardetanz aus Wassertrüdingen</h1>
  <Hero />

  {
    notice.enabled && notice.text && (
      <div class="notice" role="status">
        <div class="wrap notice__inner">
          <span class="notice__dot" aria-hidden="true"></span>
          <p>{notice.text}</p>
          {notice.link && notice.linkLabel && (
            <a class="arrow-link" href={notice.link}>{notice.linkLabel}</a>
          )}
        </div>
      </div>
    )
  }

  <!-- Kommende Termine -->
  {
    events.length > 0 && (
      <section class="section">
        <div class="wrap">
          <SectionHeading eyebrow="Bühne frei" title="Kommende Termine" intro="Wo wir als Nächstes auf der Bühne stehen." />
          <div class="events-list">
            {events.map((event) => <EventItem event={event} />)}
          </div>
          <a class="btn btn--ghost more-btn" href="/termine">Alle Termine ansehen</a>
        </div>
      </section>
    )
  }

  <!-- Unsere Garden -->
  <section class="section">
    <div class="wrap">
      <SectionHeading eyebrow="drei Garden" title="Für jedes Alter" intro="Von den ersten Schritten bis zur großen Bühne." />
      <div class="grid grid--3">
        {groups.map((group, i) => <GroupCard group={group} index={i} />)}
      </div>
    </div>
  </section>

  <!-- Aktuelles -->
  {
    posts.length > 0 && (
      <section class="section">
        <div class="wrap">
          <SectionHeading eyebrow="frisch aus dem Verein" title="Aktuelles" />
          <div class="grid grid--2">
            {posts.map((post) => <PostCard post={post} />)}
          </div>
          <a class="btn btn--ghost more-btn" href="/aktuelles">Alle Beiträge</a>
        </div>
      </section>
    )
  }

  <!-- Verein-Teaser & Mitmachen -->
  <section class="surface-cream">
    <div class="wrap verein-teaser">
      <div class="verein-teaser__text">
        <span class="eyebrow">seit 1981</span>
        <h2 class="display">{vereinTeaserTitle}</h2>
        <p>{vereinTeaserText}</p>
        <div class="verein-teaser__cta">
          <a class="btn" href="/verein">Mehr über uns</a>
          <a class="btn btn--ghost" href="/kontakt">Mitmachen &amp; Kontakt</a>
        </div>
      </div>
      <div class="verein-teaser__facts" aria-hidden="false">
        <div><strong>1981</strong><span>gegründet</span></div>
        <div><strong>3</strong><span>Garden</span></div>
        <div><strong>{site.location}</strong><span>zuhause</span></div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Aktueller Hinweis */
  .notice {
    background: color-mix(in srgb, var(--hot) 8%, #ffffff);
    border-block: 1px solid color-mix(in srgb, var(--hot) 28%, transparent);
  }

  .notice__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem 1rem;
    padding-block: 0.9rem;
  }

  .notice__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--hot);
    box-shadow: var(--glow-red);
    flex: none;
  }

  .notice p {
    margin: 0;
    font-weight: 500;
  }

  .events-list {
    border-bottom: 1px solid var(--hairline);
  }

  .more-btn {
    margin-top: var(--space-6);
  }

  /* Verein-Teaser (helle Sektion) */
  .verein-teaser {
    display: grid;
    gap: var(--space-7);
    align-items: center;
  }

  @media (min-width: 860px) {
    .verein-teaser {
      grid-template-columns: 1.5fr 1fr;
    }
  }

  .verein-teaser__text h2 {
    font-size: var(--step-3);
    margin-block: 0.4rem 0.8rem;
  }

  .verein-teaser__text p {
    max-width: 40rem;
    font-size: var(--step-1);
    color: var(--cream-ink-muted);
  }

  .verein-teaser__cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-top: var(--space-5);
  }

  .verein-teaser__facts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    text-align: center;
  }

  .verein-teaser__facts div {
    padding: var(--space-4) var(--space-2);
    border: 1px solid var(--cream-hairline);
    border-radius: var(--radius-m);
    background: #ffffff;
    box-shadow: var(--shadow-card);
  }

  .verein-teaser__facts strong {
    display: block;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.3rem, 1rem + 1.5vw, 2rem);
    line-height: 1;
    color: var(--blue-600);
  }

  .verein-teaser__facts span {
    font-size: var(--step--1);
    color: var(--cream-ink-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
</style>
