---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageIntro from '../components/PageIntro.astro';
import GroupCard from '../components/GroupCard.astro';
import { getGroups } from '../lib/collections';
---

<BaseLayout
  title="Unsere Garden"
  description="Kindergarde, Jugend-Tanzgarde und die Aktiven: die drei Gruppen der Europa-Show-Tanzgarde aus Wassertrüdingen."
>
  <PageIntro
    eyebrow="drei Garden"
    title="Unsere Garden"
    intro="Von den ersten Schritten in der Kindergarde bis zur großen Bühne mit den Aktiven – bei uns findet jedes Alter seine Gruppe."
  />

  <section class="section section--tight">
    <div class="wrap">
      <div class="grid grid--3">
        {(await getGroups()).map((group, i) => <GroupCard group={group} index={i} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap join">
      <div class="join__inner">
        <span class="eyebrow">mitmachen</span>
        <h2 class="display">Lust, mitzutanzen?</h2>
        <p>
          Neue Tänzerinnen und Tänzer sind in allen Garden willkommen. Schreib uns
          einfach – wir sagen dir, wann und wo das nächste Training stattfindet.
        </p>
        <a class="btn" href="/kontakt">Kontakt aufnehmen</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .join__inner {
    max-width: 44rem;
    padding: var(--space-7);
    border: 1px solid var(--hairline);
    border-radius: var(--radius-l);
    background:
      radial-gradient(90% 120% at 100% 0%, rgb(226 36 44 / 0.12), transparent 55%),
      var(--bg-card);
  }

  .join h2 {
    font-size: var(--step-3);
    margin-block: 0.4rem 0.8rem;
  }

  .join p {
    color: var(--text-muted);
    font-size: var(--step-1);
    margin-bottom: var(--space-5);
  }
</style>
